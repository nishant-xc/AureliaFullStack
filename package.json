{
    "name": "aurelia-fullstack-backend",
    "version": "1.0.0",
    "description": "Production-ready food delivery backend built with Node.js, Express.js and PostgreSQL.",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "lint": "eslint src tests",
        "lint:fix": "eslint src tests --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.js": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "keywords": [],
    "author": "Nishant Tiwari",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.2.0",
        "joi": "^18.2.3",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.11.0",
        "pg": "^8.22.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "uuid": "^14.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "eslint": "^9.36.0",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^16.1.6",
        "nodemon": "^3.1.14",
        "prettier": "^3.6.2",
        "supertest": "^7.2.2"
    },
    "allowScripts": {
        "unrs-resolver@1.12.2": true
    }
}
